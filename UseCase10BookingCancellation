import java.util.*;

public class UseCase10BookingCancellation {

    public static void main(String[] args) {

        HashMap<String, Integer> inventory = new HashMap<>();
        inventory.put("Single Room", 1);
        inventory.put("Double Room", 1);

        HashMap<String, String> bookings = new HashMap<>();
        bookings.put("R1", "Single Room");
        bookings.put("R2", "Double Room");

        HashMap<String, Stack<String>> releasedRooms = new HashMap<>();
        releasedRooms.put("Single Room", new Stack<>());
        releasedRooms.put("Double Room", new Stack<>());

        cancelBooking("R1", bookings, inventory, releasedRooms);
        cancelBooking("R3", bookings, inventory, releasedRooms);

        System.out.println("\nUpdated Inventory:");
        for (Map.Entry<String, Integer> entry : inventory.entrySet()) {
            System.out.println(entry.getKey() + " : " + entry.getValue());
        }
    }

    public static void cancelBooking(String reservationId,
                                     HashMap<String, String> bookings,
                                     HashMap<String, Integer> inventory,
                                     HashMap<String, Stack<String>> releasedRooms) {

        if (!bookings.containsKey(reservationId)) {
            System.out.println("Cancellation Failed: Invalid Reservation ID " + reservationId);
            return;
        }

        String roomType = bookings.get(reservationId);

        String roomId = reservationId + "_ROOM";

        releasedRooms.get(roomType).push(roomId);

        inventory.put(roomType, inventory.get(roomType) + 1);

        bookings.remove(reservationId);

        System.out.println("Cancelled: " + reservationId + " | Released Room: " + roomId);
    }
}
